-- Q1: Finding Updated Records (ID 10299)
-- Difficulty: Easy
--
-- Problem Description:
-- We have a table with employees and their salaries; however, some of the records
-- are old and contain outdated salary information. Since there is no timestamp,
-- assume salary is non-decreasing over time. The current salary for an employee 
-- is the largest salary value among their records. If multiple records share the 
-- same maximum salary, return any one of them. 
-- 
-- Required Output:
-- id, first_name, last_name, department_id, salary
-- Order the results by employee ID in ascending order.
--
-- Table: ms_employee_salary
-- Columns:
-- - id (bigint)
-- - first_name (varchar)
-- - last_name (varchar)
-- - department_id (bigint)
-- - salary (bigint)



SELECT id, first_name, last_name, department_id, salary
FROM (
    SELECT *,
           ROW_NUMBER() OVER (
               PARTITION BY id 
               ORDER BY salary DESC, department_id DESC
           ) AS row_number
    FROM ms_employee_salary
) t
WHERE row_number = 1;
